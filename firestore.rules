rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Testimonials collection security
    match /testimonials/{testimonialId} {
      // Public can see feedback
      allow read: if true; 
      
      // Anyone can submit feedback, but with validation
      allow create: if request.resource.data.name != "" 
                   && request.resource.data.text != ""
                   && request.resource.data.rating >= 1 
                   && request.resource.data.rating <= 5;
      
      // ONLY authenticated admins (specific email) can update or delete
      allow update, delete: if request.auth != null && request.auth.token.email == "ramunarlapati@gmail.com"; 
    }

    // Demo requests collection security
    match /demo_requests/{requestId} {
      // Anyone can 'get' a specific request if they have the ID (for tracking)
      allow get: if true;
      
      // ONLY authenticated admins (specific email) can list all requests or delete
      allow list, delete: if request.auth != null && request.auth.token.email == "ramunarlapati@gmail.com"; 
      
      // Anyone can submit a demo request
      allow create: if request.resource.data.name != "" 
                   && request.resource.data.email != ""
                   && request.resource.data.interest != "";
      
      // ONLY authenticated admins can delete
      allow update, delete: if request.auth != null;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
