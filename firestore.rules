rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Testimonials collection security
    match /testimonials/{testimonialId} {
      // Public can see feedback
      allow read: if true; 
      
      // Anyone can submit feedback, but with validation
      allow create: if request.resource.data.name != "" 
                   && request.resource.data.text != ""
                   && request.resource.data.rating >= 1 
                   && request.resource.data.rating <= 5;
      
      // ONLY authenticated admins (specific email) can update or delete
      allow update, delete: if request.auth != null && request.auth.token.email == "ramunarlapati@gmail.com"; 
    }

    // Demo requests collection security
    match /demo_requests/{requestId} {
      // ✅ Public can 'get' by ID for tracking (tracking ID is doc ID)
      allow get: if true;

      // ✅ Users can read (list/get) their own documents, Admin can read all
      allow read: if request.auth != null && (request.auth.token.email == "ramunarlapati@gmail.com" || resource.data.uid == request.auth.uid || resource.data.email == request.auth.token.email);
      
      // ✅ Anyone can submit a demo request
      allow create: if request.resource.data.name != "" 
                   && request.resource.data.email != ""
                   && request.resource.data.interest != "";
      
      // ❌ ONLY authenticated admins can update or delete
      allow update, delete: if request.auth != null && request.auth.token.email == "ramunarlapati@gmail.com"; 
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
